# ブラウザに公開されるSupabase設定。秘密鍵ではありません。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー側だけで使う秘密情報。
SUPABASE_SERVICE_ROLE_KEY=
APP_BASE_URL=http://localhost:3000

# 自分専用ローカルログイン。APP_ACCESS_CODE は推測されにくい値にしてください。
APP_ACCESS_CODE=
APP_USER_ID=

# Supabase Authを併用する場合だけ設定します。
ALLOWED_USER_EMAILS=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_CHUNK_MODEL=gpt-5-mini
USE_MOCK_AI=false

# YouTubeメタ情報取得。未設定でも動きますが、動画時間の自動判定精度が落ちます。
YOUTUBE_DATA_API_KEY=

# Google Drive保存。サービスアカウントに保存先フォルダ権限を付けてください。
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ローカル/Obsidian保存。Google Drive未設定でもMarkdownリンクを作ります。
OBSIDIAN_VAULT_PATH=
OBSIDIAN_TARGET_DIR=SNS発信/動画情報

# Slack DM通知。
SLACK_BOT_TOKEN=
SLACK_USER_ID=

# Macワーカー認証。Vercel側とMac側で同じ値にしてください。
WORKER_TOKEN=
